def wait_approval(state: ApprovalState) -> Command[Literal["after_approval", "cancel_node"]]:
    """等待审批节点 - 严格按照官方示例

    Returns:
        Command: 包含 interrupt 信息和下一步跳转指令
    """
    task_id = state.get("task_id", "")
    task_content = state.get("task_content", "")

    print(f"\n{'='*50}")
    print(f"[节点] wait_approval 开始执行")
    print(f"  任务ID: {task_id}")
    print(f"  任务内容: {task_content}")
    print(f"  [中断] 触发 interrupt，等待用户审批...")
    print(f"{'='*50}\n")

    # 官方模式：interrupt() 返回中断信息，存储在 result["__interrupt__"]
    # 用户确认后，decision=True，恢复后跳转到 after_approval
    # 用户拒绝后，decision=False，恢复后跳转到 cancel_node
    decision = interrupt({
        "question": "请确认是否批准该任务？",
        "task_id": task_id,
        "task_content": task_content,
    })

    # 恢复后根据决策跳转到对应节点
    print(f"\n[恢复] 用户决策: {decision}")
    return Command(goto="after_approval" if decision else "cancel_node")

