# nodes.py
from langgraph.types import interrupt

def approval_node(state):
    print("--- AI 准备执行敏感操作，请求人工审批 ---")
    
    # 这一行会产生中断。初次运行到这，函数会直接终止。
    # 当人类恢复(Resume)时，它的返回值就是人类输入的内容。
    user_decision = interrupt("你是否允许执行扣款 100 元的操作？")
    
    return {"approved": user_decision}

