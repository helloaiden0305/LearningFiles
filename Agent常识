61. 多线程 ThreadPoolExecutor 怎么用？

from concurrent.futures import ThreadPoolExecutor, as_completed
import time

def call_api(prompt):
    time.sleep(1)  # 模拟网络请求return f"结果: {prompt}"

prompts = ["问题1", "问题2", "问题3"]

# 方式一：map（保持顺序）
with ThreadPoolExecutor(max_workers=10) as executor:
    results = list(executor.map(call_api, prompts))
# 串行 3 秒，并发约 1 秒# 

方式二：submit + as_completed（谁先完成先处理）

with ThreadPoolExecutor(max_workers=10) as executor:
    futures = {executor.submit(call_api, p): p for p in prompts}
    for future in as_completed(futures):
        prompt = futures[future]
        result = future.result()
        print(f"{prompt} → {result}")

注意事项：
- max_workers 不是越大越好，I/O 密集型通常 10-50
- 注意 API Rate Limit
- 多线程写同一资源需加锁（threading.Lock）

